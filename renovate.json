{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": ["config:best-practices"],
  "labels": ["area/dependency"],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "schedule": ["* * * * 6,0"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    ".github/workflows/gen_*"
  ],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\sARG (\\w+_)?VERSION=(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/pkg.toml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) packageName=(?<packageName>\\S+) currentValue=(?<currentValue>\\S+)( versioning=(?<versioning>\\S+))?\\s+\"(?<currentDigest>[a-f0-9]{7,40})\"",
        "# renovate: datasource=(?<datasource>\\S+)( depName=(?<depName>\\S+))?( registryUrl=(?<registryUrl>\\S+))?( packageName=(?<packageName>\\S+))?( versioning=(?<versioning>\\S+))?\\s+\"(?<currentValue>\\S+)\"",
        "# renovate: datasource=(?<datasource>.*?)( versioning=(?<versioning>.*?))?\\sbase_image = \"(?<depName>[^\"]+?):(?<currentValue>[^@\"\\s]+)(?:@sha256:[a-f0-9]+)?\""
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ]
}
